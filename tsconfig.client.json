{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "none",
    "resolveJsonModule": false,
    "types": [],
    "outDir": "public/js",
    "rootDir": "src/client",
    "noEmitOnError": true
  },
  "include": ["src/client/**/*.ts", "src/types/**/*.d.ts"]
}
